<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" type="text/css" href="/style.css?<%=Time.now.to_i%>">

</head>
<body>
    <form method="POST" action="/users/login" style="display: flex;flex-direction:column;gap:10px;width:200px;">
        <label for="username">Username</label><input type="text" style="color:white;" placeholder="Username" name="username" class="normal" id="username"required><br>
        <label for="password">Password</label><input type="text" placeholder="Password" style="color:white;"name="password" class="normal" id="password" required><br>
        <a href="/users/sign-up">Sign up</a>
        <% if @failed%>
        <p style="Color:red">Too many login attempts :/</p>
        <% else %>
        <input type="submit" name="send" class="normal" value="Log in">
        <%end%>
        

    </form>
</body>
</html>