<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <form method="POST" action="/signup" style="display: flex;flex-direction:column;gap:10px;width:200px;">
        <input type="text" placeholder="Username" name="username" required>
        <input type="text" type="password "placeholder="Password" name="password" required>
        <input type="text" type="password" placeholder="Repeat password" name="repeated_password" required>
        <% if @incorrect%>
            <p style="color:red">Password do not match<p>

        <%end%>
        <input type="submit">
    </form>
</body>
</html>