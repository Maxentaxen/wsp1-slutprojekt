<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> <%=@movieinfo['name']%> - FlixMax</title>
    <link rel="stylesheet" type="text/css" href="/style.css?<%=Time.now.to_i%>">
</head>
<body >
    <h2><%=@movieinfo['name']%></h2>
    <p>Release year: <%=@movieinfo['year']%> </p>
    <div class="imdb" style="display: flex; height: 18px; flex-direction: row;">
        <img src="/img/imdblogo.png" style="">
        <p style="margin: 0;"> : <%=@movieinfo['imdb_rating']%> </p>
    </div>
    <p>Runtime: <%=@movieinfo['runtime']%> min </p>
    <p>Genre<%=@movieinfo['genres'].split(',').length > 1 ? "s": ""%>: <%= @movieinfo['genres'].split(",").join(", ")%></p>
    <img src="<%=@movieinfo['poster']%>" style="width: 300px;
                                                height:450px; 
                                                position: absolute; 
                                                right: 5%; 
                                                top: 12%;
                                                border-radius: 25px;">
    <p>Your score: <%=@review['score']%></p>
    <div class="reviewtext">
        <div id="quotemark1">“</div>
        <p><%=@review['review']%></p>
        <div id="quotemark2">”</div> 
    </div>
</body>
</html>

